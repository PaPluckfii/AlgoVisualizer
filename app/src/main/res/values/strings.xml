                        \t\t\t\t index = j;\n
                    \t\t\t }\n
                \t\t }\n
                \t\t int smallestNumber = arr[index];\n
                \t\t arr[index] = arr[i];\n
                \t\t arr[i] = smallestNumber;\n
                \t\t }\n
            \n
